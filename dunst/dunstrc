# ── Dunst — Samurai theme (matching waybar) ──

[global]
    # ── Geometry & Position ──
    width = (280, 400)
    height = 120
    origin = top-right
    offset = 12x50
    notification_limit = 4
    indicate_hidden = yes

    # ── Appearance ──
    font = JetBrainsMono Nerd Font 11
    frame_width = 2
    corner_radius = 12
    separator_height = 2
    padding = 14
    horizontal_padding = 18
    text_icon_padding = 14
    gap_size = 6

    # ── Behaviour ──
    sort = yes
    idle_threshold = 120
    show_age_threshold = 30
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no
    shrink = no

    # ── Icons ──
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48
    icon_corner_radius = 6

    # ── Progress bar ──
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    progress_bar_corner_radius = 4

    # ── Mouse actions ──
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

    # ── Wayland ──
    layer = overlay
    force_xwayland = false

# ── Low urgency — muted, subtle ──
[urgency_low]
    background = "#1a1a19E8"
    foreground = "#c5c5c5"
    frame_color = "#63575180"
    highlight = "#635751"
    timeout = 5

# ── Normal urgency — accent border like waybar modules ──
[urgency_normal]
    background = "#1a1a19F0"
    foreground = "#c5c5c5"
    frame_color = "#c8584573"
    highlight = "#c85845"
    timeout = 8

# ── Critical urgency — bold red like battery critical ──
[urgency_critical]
    background = "#1a1a19F8"
    foreground = "#c5c5c5"
    frame_color = "#c85845"
    highlight = "#cf6550"
    timeout = 0
